		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.35.1",
		"mdsvex": "^0.12.7",
		"prettier-plugin-svelte": "^3.1.2",
		"svelte": "^5.19.0",
		"svelte-check": "^4.0.0",
